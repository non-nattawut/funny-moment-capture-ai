# --- LLM Provider Selection ---
# Options: "lm_studio" or "nvidia"
LLM_PROVIDER=lm_studio

# --- LM Studio Configuration ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=not-needed
LM_STUDIO_MODEL_NAME=google/gemma-4-e4b

# --- NVIDIA NIM Configuration ---
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL_NAME=google/gemma-3n-e4b-it

# --- Whisper Configuration ---
WHISPER_MODEL_SIZE=large-v3
WHISPER_INITIAL_PROMPT=transcribe Thai only, it has no other languages

# --- Paths ---
INPUT_VIDEO_PATH=data/test.mp4
OUTPUT_DIR=output
TEMP_DIR=temp

# --- Chunking Settings ---
TRANSCRIBE_CHUNK_SIZE=2000
TRANSCRIBE_CHUNK_OVERLAP=200

# --- Hugging Face Token ---
HF_TOKEN=

# --- Clip Duration ---
MIN_CLIP_DURATION=10
MAX_CLIP_DURTATION=120